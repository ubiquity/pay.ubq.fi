{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "eslint.config.js",
    "**/*.deno.ts",
    "**/*.deno.tsx",
    "**/deno.json",
    "**/deno.jsonc",
    "serve.ts"
  ],
  "ignoreDependencies": [
    "@playwright/mcp",
    "playwright"
  ],
  "ignoreBinaries": [
    "claude"
  ],
  "ignoreIssues": {
    "src/constants/config.ts": ["exports"],
    "src/constants/supported-reward-tokens.ts": ["exports", "types"],
    "src/utils/permit-utils.ts": ["exports"],
    "src/database.types.ts": ["exports", "types"]
  },
  "entry": [
    "serve.ts!",
    "src/main.tsx!",
    "src/workers/**/*.worker.ts!"
  ],
  "project": [
    "src/**/*.ts!",
    "src/**/*.tsx!"
  ]
}
