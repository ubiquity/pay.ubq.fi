{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/extract-migration-nonces.ts",
        "scripts/sequential-migration.ts", 
        "scripts/check-migration-status.ts",
        "scripts/speed-up-migration.ts",
        "scripts/check-nonce.ts",
        "scripts/nonce-migration/analyze-nonces.ts",
        "scripts/nonce-migration/blast-migration.ts",
        "scripts/nonce-migration/continue-migration.ts",
        "scripts/nonce-migration/simple-nonce-migration.ts",
        "scripts/nonce-migration/speed-up.ts",
        "scripts/nonce-migration/check-status.ts",
        "scripts/nonce-migration/test-nonce-migration.ts"
      ],
      "project": [
        "src/backend/**/*.ts",
        "scripts/**/*.ts"
      ]
    },
    "src/frontend": {
      "entry": [
        "src/main.tsx",
        "src/workers/**/*.worker.ts"
      ],
      "project": [
        "src/**/*.ts",
        "src/**/*.tsx"
      ]
    }
  },
  "ignore": [
    "src/frontend/vite.config.ts",
    "src/frontend/eslint.config.js",
    "eslint.config.js",
    "**/*.deno.ts",
    "**/*.deno.tsx",
    "**/deno.json",
    "**/deno.jsonc",
    "scripts/rpc-diagnostics.ts"
  ],
  "ignoreDependencies": [
    "@playwright/mcp",
    "playwright",
    "puppeteer"
  ],
  "ignoreBinaries": [
    "claude"
  ],
  "vite": {
    "config": ["src/frontend/vite.config.ts"]
  }
}