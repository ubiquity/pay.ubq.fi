# Root .env.example for Server + Frontend

# --- Supabase (backend + frontend build inputs) ---

# Used by the backend server (`serve.ts`) at runtime.
# Also used in CI to set `VITE_SUPABASE_URL` for the frontend build.
SUPABASE_URL=

# Used in CI to set `VITE_SUPABASE_ANON_KEY` for the frontend build.
# Not read by browser runtime code unless you explicitly set `VITE_SUPABASE_ANON_KEY`.
SUPABASE_ANON_KEY=

# Backend only. Never expose this to the browser (service role bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# --- Frontend (Vite) Variables ---

# These must be prefixed with VITE_ to be exposed to browser/runtime code.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# RPC base URL is selected automatically:
# - on *.ubq.fi: /rpc
# - otherwise: https://rpc.ubq.fi

# --- Deployment/Contract Variables ---

# Private key for deployment (required for contract deployment scripts)
DEPLOYER_PRIVATE_KEY=

# Private key for one-off Permit2 invalidation tooling (optional; see scripts/permit2-invalidate.ts)
INVALIDATOR_PRIVATE_KEY=

# Single Etherscan API key for all chains (for contract verification)
ETHERSCAN_API_KEY=

# Note: Make sure to fund the deployer address with native tokens on each chain
# Required amounts (estimates):
# - Ethereum (ETH): ~0.01 ETH
# - Optimism (ETH): ~0.001 ETH
# - BSC (BNB): ~0.005 BNB
# - Gnosis (xDAI): ~0.1 xDAI
# - Polygon (MATIC): ~1 MATIC
# - Base (ETH): ~0.001 ETH
# - Arbitrum (ETH): ~0.001 ETH
# - Celo (CELO): ~1 CELO
# - Avalanche (AVAX): ~0.1 AVAX
# - Blast (ETH): ~0.001 ETH
# - Zora (ETH): ~0.001 ETH
