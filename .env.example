# Root .env.example for Backend

# --- Backend Environment Variables ---

# Supabase project URL (required for backend API/database access)
SUPABASE_URL=

# Supabase service role key (required for backend API/database access)
SUPABASE_SERVICE_ROLE_KEY=

# --- Deployment/Contract Variables ---

# Private key for deployment (required for contract deployment scripts)
DEPLOYER_PRIVATE_KEY=

# Single Etherscan API key for all chains (for contract verification)
ETHERSCAN_API_KEY=

# Note: Make sure to fund the deployer address with native tokens on each chain
# Required amounts (estimates):
# - Ethereum (ETH): ~0.01 ETH
# - Optimism (ETH): ~0.001 ETH
# - BSC (BNB): ~0.005 BNB
# - Gnosis (xDAI): ~0.1 xDAI
# - Polygon (MATIC): ~1 MATIC
# - Base (ETH): ~0.001 ETH
# - Arbitrum (ETH): ~0.001 ETH
# - Celo (CELO): ~1 CELO
# - Avalanche (AVAX): ~0.1 AVAX
# - Blast (ETH): ~0.001 ETH
# - Zora (ETH): ~0.001 ETH

# --- Debug Configuration ---

# Enable/disable debug logging (default: true in development, false in production)
DEBUG_ENABLED=true

# Debug log level: ERROR, WARN, INFO, DEBUG, TRACE (default: INFO)
DEBUG_LEVEL=INFO

# Debug modules to enable (comma-separated, * for all) (default: *)
DEBUG_MODULES=*

# Include timestamps in debug logs (default: true)
DEBUG_TIMESTAMP=true

# Enable colored output in debug logs (default: true in development)
DEBUG_COLORS=true

# Persist debug logs to localStorage/file (default: false)
DEBUG_PERSIST=false

# Maximum number of debug logs to keep (default: 1000)
DEBUG_MAX_LOGS=1000
