{
  "name": "pay.ubq.fi",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@cowprotocol/cow-sdk": "^5.10.2",
    "@supabase/supabase-js": "^2.56.0",
    "@tanstack/react-query": "^5.70.0",
    "@ubiquity-dao/permit2-rpc-client": "0.1.2",
    "@uniswap/permit2-sdk": "^1.3.1",
    "@wagmi/connectors": "^5.7.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0",
    "viem": "^2.24.1",
    "wagmi": "^2.14.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@playwright/mcp": "^0.0.35",
    "@types/bun": "^1.2.13",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "knip": "^5.63.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "unenv": "npm:unenv-nightly@2.0.0-20251124-134829-ab99519",
    "vite": "^6.2.0",
    "vite-plugin-node-polyfills": "^0.23.0"
  },
  "private": true,
  "scripts": {
    "_frontend": "vite --host",
    "_serve": "deno run -A --env-file=.env serve.ts",
    "_frontend-build": "vite build",
    "_browser": "/Applications/Brave\\ Browser.app/Contents/MacOS/Brave\\ Browser --remote-debugging-port=9222",
    "dev": "run-p _frontend _serve",
    "start": "run-s _frontend-build _serve",
    "build": "vite build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "deno:check": "deno check --lock=deno.lock serve.ts",
    "knip": "knip",
    "browser:cdp": "./scripts/start-browser-cdp.sh",
    "browser:cdp:chrome": "./scripts/start-browser-cdp.sh --browser=chrome",
    "browser:cdp:brave": "./scripts/start-browser-cdp.sh --browser=brave",
    "playwright:setup": "claude mcp add playwright bunx '@playwright/mcp@latest' -- --cdp-endpoint=\"http://localhost:9222\""
  }
}
