{
  "name": "pay.ubq.fi-root",
  "version": "1.0.0",
  "dependencies": {
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "private": true,
  "scripts": {
    "start": "PORT=8080 NODE_ENV=development cd frontend && bun run build && cd ../backend && bun run server.ts",
    "frontend:dev": "cd frontend && bun run dev",
    "backend:dev": "cd backend && bun run server.ts",
    "build": "run-p frontend:build backend:build",
    "frontend:build": "cd frontend && bun run build",
    "backend:build": "cd backend && bun run build",
    "install": "run-p frontend:install backend:install",
    "frontend:install": "cd frontend && bun install",
    "backend:install": "cd backend && bun install",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules"
  }
}
