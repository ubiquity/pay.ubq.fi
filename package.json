{
  "name": "pay.ubq.fi-root",
  "version": "1.0.0",
  "dependencies": {
    "axios": "^1.9.0",
    "ethers": "^6.14.1",
    "node-fetch": "^2.6.7",
    "puppeteer": "^24.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/bun": "^1.2.13",
    "@types/node-fetch": "^2.6.11",
    "@wagmi/core": "^2.17.2",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "knip": "^5.45.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "solc": "^0.8.30",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "viem": "^2.30.0"
  },
  "private": true,
  "scripts": {
    "_frontend": "cd src/frontend && bun run dev --host",
    "_backend": "bun run src/backend/server.ts",
    "_frontend-build": "cd src/frontend && bun run build",
    "_browser": "/Applications/Brave\\ Browser.app/Contents/MacOS/Brave\\ Browser --remote-debugging-port=9222",
    "dev": "run-p _frontend _backend",
    "start": "run-s _frontend-build _backend",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/ *.js *.json *.md",
    "format:check": "prettier --check src/ *.js *.json *.md",
    "type-check": "tsc --noEmit",
    "knip": "knip"
  }
}
