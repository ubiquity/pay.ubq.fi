{
  "name": "pay.ubq.fi",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.56.0",
    "commander": "^14.0.0",
    "hono": "^4.6.14",
    "puppeteer": "^24.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@playwright/mcp": "^0.0.35",
    "@types/bun": "^1.2.13",
    "eslint": "^9.34.0",
    "eslint-plugin-check-file": "^3.3.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-sonarjs": "^3.0.5",
    "globals": "^16.3.0",
    "knip": "^5.63.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "viem": "^2.34.0"
  },
  "private": true,
  "scripts": {
    "_frontend": "cd src/frontend && bun run dev --host",
    "_backend": "bun run src/backend/server.ts",
    "_frontend-build": "cd src/frontend && bun run build",
    "_browser": "/Applications/Brave\\ Browser.app/Contents/MacOS/Brave\\ Browser --remote-debugging-port=9222",
    "dev": "run-p _frontend _backend",
    "start": "run-s _frontend-build _backend",
    "build": "cd src/frontend && bun run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "browser:cdp": "./scripts/start-browser-cdp.sh",
    "browser:cdp:chrome": "./scripts/start-browser-cdp.sh --browser=chrome",
    "browser:cdp:brave": "./scripts/start-browser-cdp.sh --browser=brave",
    "playwright:setup": "claude mcp add playwright bunx '@playwright/mcp@latest' -- --cdp-endpoint=\"http://localhost:9222\"",
    "migration:analyze": "bun scripts/nonce-migration/analyze-nonces.ts",
    "migration:run": "bun scripts/nonce-migration/run-migration.ts",
    "migration:run:dry": "bun scripts/nonce-migration/run-migration.ts --dry-run",
    "migration:speed-up": "bun scripts/nonce-migration/speed-up.ts",
    "migration:status": "bun scripts/nonce-migration/check-status.ts",
    "migration:test": "bun scripts/nonce-migration/test-nonce-migration.ts --dry-run"
  }
}
