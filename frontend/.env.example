# frontend/.env.example
# Copy this file to frontend/.env and fill in the values.
# All frontend environment variables must be prefixed with VITE_ to be accessible in the app.

# --- Frontend Environment Variables ---

# Supabase project URL (required for frontend to connect to Supabase)
VITE_SUPABASE_URL=

# Supabase anon/public key (required for frontend to connect to Supabase)
VITE_SUPABASE_ANON_KEY=

# Blockchain RPC endpoint for all on-chain calls (required)
# In development, this is set to https://rpc.ubq.fi
# In production, this is set to /rpc
